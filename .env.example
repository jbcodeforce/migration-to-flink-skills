# Shared environment for all migration skill harnesses (ksql-to-flink, spark-to-flink).
# Copy to .env at this repo root: cp .env.example .env
#
# Optional: point harnesses at an external reusable env file instead:
# export DOTENV_FILE=/path/to/my-reusable.env
# Relative paths resolve against this repo root.

# LLM (translation)
SL_LLM_BASE_URL=http://localhost:7999/v1
SL_LLM_MODEL==Qwen3.6-27B-PARO
SL_LLM_API_KEY=local-key
SL_LLM_TIMEOUT=10

# ksql-to-flink fixture root (optional)
KSQL_TUTORIAL_ROOT=references/ksql/

# spark-to-flink fixture roots (optional overrides)
SPARK_PROJECT_ROOT=references/spark

# Flink deploy (confluent-sql REST API)
FLINK_DEPLOY_POLL_SECONDS=5
FLINK_DEPLOY_TIMEOUT_SECONDS=300
# Legacy aliases (optional): MCP_DEPLOY_POLL_SECONDS, MCP_DEPLOY_TIMEOUT_SECONDS

# Agent deploy fixer: 0 = disabled, 1 = enabled
AGENT_FIXER_EXECUTION_ENABLED=1
AGENT_FIXER_EXECUTION_MAX_RETRIES=2

# CLI logging (default: harness/logs/ksql-flink-cli.log)
# FLINK_LOG_FILE=logs/ksql-flink-cli.log
# FLINK_LOG_LEVEL=DEBUG

# Flink (required for deploy)
FLINK_REST_ENDPOINT=https://flink.region.provider.confluent.cloud
FLINK_API_KEY=
FLINK_API_SECRET=
FLINK_ORG_ID=
FLINK_ENV_ID=
FLINK_COMPUTE_POOL_ID=lfcp-xxxxx
FLINK_CATALOG_NAME=
FLINK_DATABASE_NAME=
CLOUD_PROVIDER=aws
CLOUD_REGION=us-west-2
