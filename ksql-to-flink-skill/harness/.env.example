# Deprecated: use repo-root .env.example instead (../../.env.example from harness).
# LLM (translation)
SL_LLM_BASE_URL=http://localhost:1337/v1
SL_LLM_MODEL=qwen3-coder-30b-a3b-instruct-mlx-4bit
SL_LLM_API_KEY=local-key
SL_LLM_TIMEOUT=10


# Flink deploy (confluent-sql REST API)
FLINK_DEPLOY_POLL_SECONDS=5
FLINK_DEPLOY_TIMEOUT_SECONDS=300
# Legacy aliases (optional): MCP_DEPLOY_POLL_SECONDS, MCP_DEPLOY_TIMEOUT_SECONDS

# below controls if we want another agent to fix deployment issues 0: no, 1: yes
AGENT_FIXER_EXECUTION_ENABLED=1
AGENT_FIXER_EXECUTION_MAX_RETRIES=2


# CLI logging (default: harness/logs/ksql-flink-cli.log)
# KSQL_FLINK_LOG_FILE=logs/ksql-flink-cli.log
# KSQL_FLINK_LOG_LEVEL=DEBUG

# Flink (required for deploy)
FLINK_REST_ENDPOINT=https://flink.region.provider.confluent.cloud
FLINK_API_KEY=
FLINK_API_SECRET=
FLINK_ORG_ID=
FLINK_ENV_ID=
FLINK_COMPUTE_POOL_ID=lfcp-xxxxx
FLINK_CATALOG_NAME=
FLINK_DATABASE_NAME=
CLOUD_PROVIDER=aws
CLOUD_REGION=us-west-2
